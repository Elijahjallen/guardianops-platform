generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Case {
  id          String   @id @default(cuid())
  caseNumber  String   @unique
  clientName  String
  status      String
  destination String
  pickupDate  DateTime
  staffName   String?
  createdAt   DateTime @default(now())
}

model Staff {
  id          String   @id @default(cuid())
  employeeId  String   @unique
  name        String
  role        String
  status      String
  phone       String
  email       String
  homeAirport String
  createdAt   DateTime @default(now())
}

model Client {
  id         String   @id @default(cuid())
  clientCode String   @unique
  name       String
  type       String
  contact    String
  phone      String
  email      String
  location   String
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  severity  String
  createdAt DateTime @default(now())
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       String
  createdAt  DateTime @default(now())
  clientName String?
}

model CaseActivity {
  id          String   @id @default(cuid())
  caseId      String
  caseNumber  String
  title       String
  description String
  createdBy   String
  createdAt   DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  caseId     String
  senderId   String
  senderName String
  senderRole String
  content    String
  createdAt  DateTime @default(now())
}

model CaseDocument {
  id           String   @id @default(cuid())
  caseId       String
  caseNumber   String
  fileName     String
  originalName String
  filePath     String
  fileType     String
  uploadedBy   String
  createdAt    DateTime @default(now())
}

model YouthProfile {
  id                      String   @id @default(cuid())
  caseId                  String   @unique
  caseNumber              String

  firstName               String
  middleName              String?
  lastName                String
  preferredName           String?
  dateOfBirth             DateTime
  gender                  String
  identifiesNonBinary     Boolean  @default(false)
  identifiesTransgender   Boolean  @default(false)
  pronouns                String?

  autismSpectrumDisorder  Boolean  @default(false)
  autismSpectrumLevel     String?

  height                  String?
  weight                  String?
  hairColor               String?
  eyeColor                String?
  marks                   String?

  likes                   String?
  dislikes                String?
  participatingBehavior   String?
  impulsiveBehavior       String?

  siblingsInHome          String?
  familyDynamics          String?
  bedroomLayout           String?

  sportsOrHobbies         String?
  athleticLevel           String?

  custody                 String?
  biologicalOrAdopted     String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
